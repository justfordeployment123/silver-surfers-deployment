# Python Scanner Service Environment Variables
# Copy this file to .env and update values as needed

# Service Configuration
PORT=8001
HOST=0.0.0.0

# Temporary Directory for Reports
# Default: /tmp (inside container)
# For Docker: Use volume mount to persist reports
TEMP_DIR=/tmp

# Python Scanner URL (used by Node.js to connect)
# For Docker: Use container name or service name
# For local: Use localhost
PYTHON_SCANNER_URL=http://localhost:8001

# Python Settings
PYTHONUNBUFFERED=1

# Uvicorn Configuration
LIMIT_CONCURRENCY=10
TIMEOUT_KEEP_ALIVE=300

# Optional: Logging
LOG_LEVEL=INFO

# Optional: Camoufox Configuration
# Camoufox will automatically download browser on first run
# No additional configuration needed

# Optional: SQS worker mode for Fargate scanner workers
# Run with: python python-scanner/sqs_worker.py
SCANNER_SQS_JOB_QUEUE_URL=
SCANNER_SQS_RESULT_QUEUE_URL=
SCANNER_SQS_ARTIFACT_BUCKET=
SCANNER_SQS_ARTIFACT_REGION=
SCANNER_SQS_ARTIFACT_PREFIX=silver-surfers/scanner-results
SCANNER_SQS_WAIT_TIME_SECONDS=20
SCANNER_SQS_JOB_VISIBILITY_TIMEOUT_SECONDS=900



