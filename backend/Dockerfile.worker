# syntax=docker/dockerfile:1

# ────────────────────────────────────────────────────────────────
# Stage 1: deps
# ────────────────────────────────────────────────────────────────
FROM node:22-bookworm-slim AS deps

# Install a pinned pnpm version. Avoid pnpm@latest/Corepack drift in Coolify builds.
RUN npm install -g pnpm@10.14.0

WORKDIR /usr/src/app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --prod --frozen-lockfile

# ────────────────────────────────────────────────────────────────
# Stage 2: worker — background job processor
# The worker dispatches audit jobs to the scanner service over HTTP,
# so it does NOT need a local Chromium. It still needs the full
# node_modules (BullMQ, Mongoose, PDF generation, OpenAI, etc.)
# ────────────────────────────────────────────────────────────────
FROM node:22-bookworm-slim AS final

ENV NODE_ENV=production \
    PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

WORKDIR /usr/src/app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    dumb-init \
    && rm -rf /var/lib/apt/lists/*

COPY --from=deps /usr/src/app/node_modules ./node_modules
COPY . .

RUN chown -R node:node /usr/src/app

USER node

# Worker does not expose an HTTP port — it connects outbound to
# Redis (BullMQ) and the scanner service.
ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "--import", "./scripts/register-typescript-loader.mjs", "src/worker.ts"]
